#!/usr/bin/env python3
"""
Wrapper script for Obsidian Clipper.
This allows running from GNOME keyboard shortcuts
without needing to specify full uv paths.
"""

import subprocess
import sys
from pathlib import Path

# Get the directory where this script is located
SCRIPT_DIR = Path(__file__).resolve().parent
PROJECT_DIR = str(SCRIPT_DIR)

# Run the clipper, forwarding any command-line arguments
subprocess.run(
    ["uv", "run", "--directory", PROJECT_DIR, "obsidian-clipper"] + sys.argv[1:],
    cwd=PROJECT_DIR,
)
